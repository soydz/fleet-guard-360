# Port where the API Gateway will run
SPRING_PORT=8080

# Comma-separated list of allowed CORS origins (for local dev, adjust as needed)
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# Base URIs of downstream services consumed by the gateway
# Auth service base URL (the gateway route will match /auth/**)
AUTH_SERVICE_URI=http://auth:8080

# Alerts service base URL (the gateway route will match /alerts/graphql/**)
ALERTS_SERVICE_URI=http://alerts:8080

NOTIFICATIONS_SERVICE_URI=notifications:8080

PANEL_SERVICE_URI=http://panel:8080

# JWT signing/verification key used by the AuthenticationFilter
# Use a strong secret in production; this is only for local dev
SECURITY_JWT_KEY_PRIVATE=bb8731318461e78dsfkjds3552lkh25klq
